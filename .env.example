# ── Core ──
SECRET_KEY=replace-with-a-long-random-50-character-secret-key-value
DEBUG=True
ALLOWED_HOSTS=*
APP_TIMEZONE=Africa/Lagos

# ── Database ──
# DB_CONNECTION: sqlite (default) | mysql | pgsql
# To run against the EXISTING Laravel database, point these at the same MySQL DB.
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jaraman
DB_USERNAME=root
DB_PASSWORD=

# ── Auth / JWT ──
JWT_TTL_DAYS=7

# ── CORS ──
CORS_ALLOW_ALL=True

# ── Payments / SMS / Push ──
PAYMENT_DEFAULT_GATEWAY=paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
TERMII_API_KEY=
TERMII_SENDER_ID=Jaraman
TERMII_BASE_URL=https://api.ng.termii.com
FIREBASE_CREDENTIALS=

# ── Email ──
# Default is the console backend (prints emails to stdout). For real SMTP set:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Jaraman <no-reply@jaraman.local>

# ── Celery (queued jobs) ──
# EAGER=True runs jobs inline (no broker needed). For real async workers set
# CELERY_TASK_ALWAYS_EAGER=False, a broker URL, then run:
#   celery -A jaraman worker -l info
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Webhooks ──
# Verify the Paystack X-Paystack-Signature (HMAC-SHA512). Defaults to ON when DEBUG=False.
PAYSTACK_VERIFY_WEBHOOK=False

# ── WebSockets (Channels) ──
# Empty = in-memory layer (single process). For production set a redis URL:
CHANNEL_REDIS_URL=
